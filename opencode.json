{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "angular-cli": {
      "type": "local",
      "command": ["npx", "-y", "@angular/cli", "mcp"],
      "enabled": true
    },
    "vitest": {
      "enabled": true,
      "command": ["npx", "-y", "@djankies/vitest-mcp"],
      "type": "local"
    },
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp"]
    },
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    }
  }
}
