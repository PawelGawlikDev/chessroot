{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "angular-cli": {
      "type": "local",
      "command": ["npx", "-y", "@angular/cli", "mcp"],
      "enabled": true
    },
    "design-token-bridge": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "design-token-bridge-mcp"]
    },
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp"]
    }
  }
}
