{
  "name": "chess-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ng build",
    "build-storybook": "ng run chess-app:build-storybook",
    "cz": "cz",
    "deploy": "ng build && wrangler deploy --env production",
    "deploy:dev": "ng build && wrangler deploy --env development",
    "e2e": "playwright test",
    "e2e:debug": "cross-env E2E=true DEBUG=true playwright test --debug",
    "lint": "yarn eslint . --ext .ts",
    "ng": "ng",
    "prepare": "husky",
    "prettier": "prettier --write .",
    "release": "standard-version && git push --follow-tags",
    "release:major": "standard-version --release-as major && git push --follow-tags",
    "release:minor": "standard-version --release-as minor && git push --follow-tags",
    "start": "ng serve",
    "storybook": "ng run chess-app:storybook",
    "test": "ng test",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.{ts,html,json,yml,yaml,md,css,scss}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "disableEmoji": true
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/cdk": "~22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-server": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@bity/oauth2-auth-code-pkce": "^2.13.0",
    "@mliebelt/pgn-parser": "^1.4.19",
    "@mliebelt/pgn-types": "^1.0.4",
    "@ngrx/effects": "^21.1.1",
    "@ngrx/signals": "^21.1.1",
    "chart.js": "^4.5.1",
    "chess.js": "^1.4.0",
    "chessground": "9.2.1",
    "chessops": "^0.15.0",
    "date-fns": "^4.4.0",
    "express": "^5.1.0",
    "fzstd": "^0.1.1",
    "jasmine-marbles": "^0.9.2",
    "jszip": "^3.10.1",
    "ngx-chessground": "21.2.12",
    "rxjs": "~7.8.2",
    "snabbdom": "3.6.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.2",
    "@analogjs/vitest-angular": "^2.6.2",
    "@angular-devkit/architect": "^0.2200.4",
    "@angular-devkit/build-angular": "^22.0.4",
    "@angular-devkit/core": "^22.0.4",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.4",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@compodoc/compodoc": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@ngrx/store": "^21.1.1",
    "@ngrx/store-devtools": "^21.1.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "4.1.9",
    "angular-eslint": "^22.0.0",
    "canvas": "^3.2.3",
    "commitizen": "^4.3.2",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prettier-eslint": "^17.1.1",
    "standard-version": "^9.5.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "packageManager": "yarn@4.17.0",
  "standard-version": {
    "scripts": {
      "postchangelog": "prettier --write CHANGELOG.md"
    }
  }
}
