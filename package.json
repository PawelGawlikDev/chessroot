{
  "name": "chess-app",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ng build",
    "cz": "cz",
    "deploy": "ng build && wrangler deploy --env production",
    "deploy:dev": "ng build && wrangler deploy --env development",
    "e2e": "playwright test",
    "e2e:debug": "cross-env E2E=true DEBUG=true playwright test --debug",
    "lint": "yarn eslint . --ext .ts",
    "ng": "ng",
    "prepare": "husky",
    "prettier": "prettier --write .",
    "release": "standard-version && git push --follow-tags",
    "release:major": "standard-version --release-as major && git push --follow-tags",
    "release:minor": "standard-version --release-as minor && git push --follow-tags",
    "start": "ng serve",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "test:ui": "ng test --ui"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.{ts,html,json,yml,yaml,md,css,scss}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "disableEmoji": true
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "21.0.1",
    "@angular/cdk": "22.0.5",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/material": "22.0.5",
    "@angular/platform-browser": "22.0.7",
    "@angular/platform-server": "22.0.7",
    "@angular/router": "22.0.7",
    "@bity/oauth2-auth-code-pkce": "2.13.0",
    "@mliebelt/pgn-parser": "1.4.19",
    "@mliebelt/pgn-types": "1.0.4",
    "@ngrx/effects": "21.1.1",
    "@ngrx/signals": "21.1.1",
    "chart.js": "4.5.1",
    "chess.js": "1.4.0",
    "chessground": "9.2.1",
    "chessops": "0.15.1",
    "date-fns": "4.4.0",
    "express": "5.2.1",
    "fzstd": "0.1.1",
    "jasmine-marbles": "0.9.2",
    "jszip": "3.10.1",
    "ngx-chessground": "21.2.12",
    "rxjs": "~7.8.2",
    "snabbdom": "3.6.4",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.3",
    "@analogjs/vitest-angular": "2.6.3",
    "@angular-devkit/architect": "0.2200.7",
    "@angular-devkit/build-angular": "22.0.7",
    "@angular-devkit/core": "22.0.7",
    "@angular-eslint/eslint-plugin": "22.1.0",
    "@angular-eslint/eslint-plugin-template": "22.1.0",
    "@angular-eslint/template-parser": "22.1.0",
    "@angular/build": "22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@angular/material": "22.0.5",
    "@angular/platform-browser-dynamic": "22.0.7",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@compodoc/compodoc": "2.0.0",
    "@eslint/js": "10.0.1",
    "@ngrx/store": "21.1.1",
    "@ngrx/store-devtools": "21.1.1",
    "@playwright/test": "1.61.1",
    "@types/express": "5.0.6",
    "@types/node": "20.19.43",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "angular-eslint": "22.1.0",
    "canvas": "3.2.3",
    "commitizen": "4.3.2",
    "cross-env": "10.1.0",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.1.0",
    "playwright": "1.61.1",
    "prettier": "3.9.5",
    "prettier-eslint": "17.1.1",
    "standard-version": "9.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "packageManager": "yarn@4.17.0",
  "standard-version": {
    "scripts": {
      "postchangelog": "prettier --write CHANGELOG.md"
    }
  }
}
